# Environment Variables
# Copy this file to .env and fill in the values

# Database
POSTGRES_USER=digitus
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=digitus_engine
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://digitus:your_password_here@db:5432/digitus_engine

# Redis
REDIS_URL=redis://redis:6379/0

# AI API
GEMINI_API_KEY=your-gemini-api-key-here

# App
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Skorlama Katsayıları
ADS_EPSILON=0.01
SEO_COMPETITION_WEIGHT=1.0
SOCIAL_TREND_WEIGHT=3.0

# Ads generation
ADS_FALLBACK_ENABLED=true
